<Window x:Class="FoodLy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        Title="FoodLy" Height="720" Width="1080"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA">
    <Window.Resources>
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0056b3"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004085"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBlock Style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Regular"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="Введите текст"/>
        </Style>

        <!-- PasswordBox Style -->
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="Введите пароль"/>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="ToolTip" Value="Выберите опцию"/>
        </Style>

        <!-- ListBox Style -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- DatePicker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="ToolTip" Value="Выберите дату"/>
        </Style>

        <!-- ProgressBar Style -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="#E9ECEF"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Border Background="#007BFF" Height="60" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                <TextBlock x:Name="LoyaltyPointsTextBlock" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Hidden"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Margin="0,60,0,0">
            <TabControl BorderThickness="0" Background="Transparent">
                <!-- Login Tab -->
                <TabItem Header="Вход" FontSize="14">
                    <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                        <StackPanel MaxWidth="400">
                            <TextBlock Text="Добро пожаловать в FoodLy" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                            <TextBlock Text="Логин"/>
                            <TextBox x:Name="LoginTextBox"/>
                            <TextBlock Text="Пароль" Margin="0,10,0,5"/>
                            <PasswordBox x:Name="PasswordBox"/>
                            <Button Content="Войти" Click="LoginButton_Click" Margin="0,20,0,10"/>
                            <Button Content="Создать аккаунт" Click="ShowRegistrationFields" Style="{x:Null}" Background="Transparent" Foreground="#007BFF" BorderThickness="0"/>
                            <StackPanel x:Name="RegistrationFields" Visibility="Collapsed" Margin="0,20,0,0">
                                <TextBlock Text="Регистрация" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="ФИО"/>
                                <TextBox x:Name="FullNameTextBox"/>
                                <TextBlock Text="Дата рождения"/>
                                <DatePicker x:Name="BirthDatePicker"/>
                                <TextBlock Text="Номер телефона"/>
                                <TextBox x:Name="PhoneNumberTextBox"/>
                                <TextBlock Text="Роль"/>
                                <ComboBox x:Name="RoleComboBox">
                                    <ComboBoxItem Content="Пользователь"/>
                                    <ComboBoxItem Content="Курьер"/>
                                    <ComboBoxItem Content="Администратор"/>
                                </ComboBox>
                                <Button Content="Зарегистрироваться" Click="RegisterButton_Click" Margin="0,20,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Menu Tab -->
                <TabItem Header="Меню" Name="UserMenuTab" Visibility="Hidden" FontSize="14">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox x:Name="CategoryComboBox" Width="200" SelectionChanged="CategoryComboBox_SelectionChanged">
                                <ComboBoxItem Content="Все"/>
                                <ComboBoxItem Content="Салаты"/>
                                <ComboBoxItem Content="Супы"/>
                                <ComboBoxItem Content="Основные блюда"/>
                                <ComboBoxItem Content="Напитки"/>
                                <ComboBoxItem Content="Завтраки"/>
                            </ComboBox>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
                            <ListBox x:Name="MenuListBox" SelectionMode="Multiple" SelectionChanged="MenuListBox_SelectionChanged">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" CornerRadius="8" Width="140" Height="140" Margin="5" Padding="10"
                                                BorderBrush="#DEE2E6" BorderThickness="1">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="120"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                        <Border Grid.Row="2" Background="White" CornerRadius="10" Margin="0,10,0,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Ингредиенты:" FontWeight="Bold"/>
                                <TextBlock x:Name="IngredientsTextBlock" TextWrapping="Wrap"/>
                                <TextBlock Text="Калории:" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock x:Name="CaloriesTextBlock"/>
                                <Button Content="Добавить в корзину" Click="AddToCart_Click" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Cart Tab -->
                <TabItem Header="Корзина" Name="CartTab" Visibility="Hidden" FontSize="14">
                    <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Ваша корзина" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                                <ListBox x:Name="CartListBox" Height="200" Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                                <TextBlock Text="{Binding Name}" Width="250"/>
                                                <TextBlock Text="{Binding Quantity, StringFormat=x{0}}" Width="50"/>
                                                <Button Content="-" Click="CartDecreaseQuantity_Click" Tag="{Binding}" Width="30"/>
                                                <Button Content="+" Click="CartIncreaseQuantity_Click" Tag="{Binding}" Width="30"/>
                                                <TextBlock Text="{Binding TotalPrice, StringFormat={}{0} руб.}" Width="100"/>
                                                <Button Content="Удалить" Click="RemoveFromCart_Click" Tag="{Binding}" Width="80" Margin="5,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="Бонусные баллы:" FontWeight="Bold"/>
                                <TextBlock x:Name="AvailablePointsTextBlock" Text="0 баллов" Margin="0,0,0,10"/>
                                <TextBlock Text="Использовать баллы:" FontWeight="Bold"/>
                                <TextBox x:Name="PointsToUseTextBox" Width="100" Margin="0,0,0,10" ToolTip="Введите количество баллов для использования"/>
                                <Button Content="Применить баллы" Click="ApplyPoints_Click" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TotalPriceTextBlock" FontSize="16" FontWeight="Bold"/>
                                <Button Content="Очистить корзину" Click="ClearCart_Click" Margin="0,10,0,10" Background="#DC3545" ToolTip="Удалить все товары из корзины"/>
                                <TextBlock Text="Адрес доставки" FontWeight="Bold" Margin="0,20,0,5"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Улица" FontWeight="Bold"/>
                                        <TextBox x:Name="CartStreetTextBox" ToolTip="Введите улицу"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Квартира" FontWeight="Bold"/>
                                        <TextBox x:Name="CartApartmentTextBox" Width="100" ToolTip="Введите квартиру"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Text="Подъезд" FontWeight="Bold"/>
                                        <TextBox x:Name="CartEntranceTextBox" Width="100" ToolTip="Введите подъезд"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="10,0,0,0">
                                        <TextBlock Text="Этаж" FontWeight="Bold"/>
                                        <TextBox x:Name="CartFloorTextBox" Width="100" ToolTip="Введите этаж"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Номер телефона" FontWeight="Bold"/>
                                <TextBox x:Name="CartPhoneNumberTextBox" ToolTip="Введите номер телефона"/>
                                <TextBlock Text="Способ оплаты" FontWeight="Bold" Margin="0,10,0,5"/>
                                <ComboBox x:Name="CartPaymentMethodComboBox" Width="200">
                                    <ComboBoxItem Content="Наличные"/>
                                    <ComboBoxItem Content="Карта"/>
                                </ComboBox>
                                <Button Content="Оформить заказ" Click="PlaceOrder_Click" Margin="0,20,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <!-- User Orders Tab -->
                <TabItem Header="Мои заказы" Name="UserOrdersTab" Visibility="Hidden" FontSize="14">
                    <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Ваши заказы" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                            <ListBox x:Name="UserOrdersListBox" Height="400" SelectionChanged="UserOrdersListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,5">
                                            <StackPanel>
                                                <TextBlock Text="{Binding OrderSummary}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding OrderDate}"/>
                                                <TextBlock Text="{Binding DeliveryTime}"/>
                                                <TextBlock Text="{Binding Address}"/>
                                                <TextBlock Text="{Binding PhoneNumber}"/>
                                                <TextBlock Text="{Binding PaymentMethod}"/>
                                                <TextBlock Text="{Binding Status}"/>
                                                <TextBlock Text="{Binding CourierInfo}"/>
                                                <ProgressBar Value="{Binding ProgressValue}" Foreground="{Binding StatusColor}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="Отменить заказ" Click="CancelOrderButton_Click" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Courier Orders Tab -->
                <TabItem Header="Заказы курьера" Name="CourierOrdersTab" Visibility="Hidden" FontSize="14">
                    <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Доступные заказы" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                            <ListBox x:Name="OrdersListBox" Height="400" SelectionChanged="OrdersListBox_SelectionChanged"/>
                            <Button Content="Взять заказ" Click="TakeOrderButton_Click" Margin="0,10,0,5"/>
                            <Button Content="Подтвердить доставку" Click="ConfirmDeliveryButton_Click"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Admin Panel Tab -->
                <TabItem Header="Администрирование" Name="AdminPanelTab" Visibility="Hidden" FontSize="14">
                    <Border Background="White" CornerRadius="10" Margin="20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Панель администратора" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                            <!-- Menu Management -->
                            <TextBlock Text="Управление меню" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Название блюда"/>
                                    <TextBox x:Name="AdminMenuNameTextBox"/>
                                    <TextBlock Text="Цена"/>
                                    <TextBox x:Name="AdminMenuPriceTextBox"/>
                                    <TextBlock Text="Ингредиенты"/>
                                    <TextBox x:Name="AdminMenuIngredientsTextBox"/>
                                    <TextBlock Text="Калории"/>
                                    <TextBox x:Name="AdminMenuCaloriesTextBox"/>
                                    <TextBlock Text="Категория"/>
                                    <ComboBox x:Name="AdminMenuCategoryComboBox">
                                        <ComboBoxItem Content="Салаты"/>
                                        <ComboBoxItem Content="Супы"/>
                                        <ComboBoxItem Content="Основные блюда"/>
                                        <ComboBoxItem Content="Напитки"/>
                                        <ComboBoxItem Content="Завтраки"/>
                                    </ComboBox>
                                    <Button Content="Добавить блюдо" Click="AddMenuItem_Click" Margin="0,10,0,0"/>
                                </StackPanel>
                                <ListBox x:Name="AdminMenuListBox" Grid.Column="1" Width="300" Margin="20,0,0,0" Height="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Width="200"/>
                                                <Button Content="Удалить" Click="DeleteMenuItem_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>

                            <!-- User Management -->
                            <TextBlock Text="Управление пользователями" FontSize="18" FontWeight="Bold" Margin="0,20,0,10"/>
                            <ListBox x:Name="AdminUsersListBox" Height="150" Margin="0,0,0,10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <TextBlock Text="{Binding Login}" Width="150"/>
                                            <TextBlock Text="{Binding Role}" Width="100"/>
                                            <TextBlock Text="{Binding LoyaltyPoints, StringFormat=Баллы: {0}}" Width="100"/>
                                            <TextBlock Text="{Binding IsBlocked, StringFormat=Заблокирован: {0}}" Width="100"/>
                                            <Button Content="Заблокировать/Разблокировать" Click="ToggleBlockUser_Click" Tag="{Binding Login}"/>
                                            <Button Content="Удалить" Click="DeleteUser_Click" Tag="{Binding Login}" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Orders Analytics -->
                            <TextBlock Text="Аналитика заказов" FontSize="18" FontWeight="Bold" Margin="0,20,0,10"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox x:Name="AdminOrderStatusComboBox" Width="200" SelectionChanged="AdminOrderStatusComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Все"/>
                                    <ComboBoxItem Content="Новый"/>
                                    <ComboBoxItem Content="В доставке"/>
                                    <ComboBoxItem Content="Доставлен"/>
                                    <ComboBoxItem Content="Отменен"/>
                                </ComboBox>
                            </StackPanel>
                            <ListBox x:Name="AdminOrdersListBox" Height="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" CornerRadius="8" Padding="10" Margin="0,5">
                                            <StackPanel>
                                                <TextBlock Text="{Binding OrderSummary}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding OrderDate}"/>
                                                <TextBlock Text="{Binding DeliveryTime}"/>
                                                <TextBlock Text="{Binding Address}"/>
                                                <TextBlock Text="{Binding PhoneNumber}"/>
                                                <TextBlock Text="{Binding PaymentMethod}"/>
                                                <TextBlock Text="{Binding Status}"/>
                                                <TextBlock Text="{Binding CourierInfo}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>